  "type": "module",
  "description": "A project built with Bun",
  "author": "Your Name <you@example.com>",
  "license": "MIT",
  "scripts": {
    "tauri": "bun run tauri dev",
    "dev": "bun vite --mode .env.development",
    "prod": "bun vite --mode .env.production",
    "test": "bun vite --mode .env.test",
    "build": "bun vue-tsc -b && bun vite build",
    "preview": "bun vite preview",
    "format": "prettier --write .",
    "preinstall": "echo '开始下载安装依赖包...'",
    "postinstall": "echo '依赖包下载完成...'"
  },
